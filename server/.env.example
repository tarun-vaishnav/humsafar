# ─────────────────────────────────────────────────────────────
# HumSafar API — environment configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# Database — Neon or Supabase (Postgres, free tier)
# Neon:     postgresql://user:pass@ep-xxx.region.aws.neon.tech/humsafar?sslmode=require
# Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres?sslmode=require
DATABASE_URL="postgresql://user:password@host/humsafar?sslmode=require"

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Comma-separated list of allowed browser origins (production)
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Email — Resend (free tier). Verify your sending domain for SPF/DKIM/DMARC.
# For a quick test you can use onboarding@resend.dev as EMAIL_FROM.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="HumSafar <noreply@your-domain.com>"
# Inquiries are delivered to this inbox (your email):
ADMIN_EMAIL=you@your-domain.com

# Cloudflare Turnstile (bot protection / captcha)
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=0x_xxxxxxxxxxxxxxxxxxxx
# Set to "true" to hard-require a valid captcha (recommended in production).
TURNSTILE_ENFORCE=false

# ── Admin dashboard ───────────────────────────────────────────
# Secret used to sign admin session JWTs. Generate a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# In production this MUST be unique and >= 32 chars, or the server refuses to boot.
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-characters
JWT_EXPIRES_IN=8h
# Obscure admin base path (defense-in-depth). The panel lives at
# /<ADMIN_PATH_SECRET> on the frontend and /api/<ADMIN_PATH_SECRET> on the API.
# Must match the frontend VITE_ADMIN_PATH. Change this from the default!
ADMIN_PATH_SECRET=change-me-to-a-random-url-segment
# Coarse IP geolocation for abuse tracking (free, keyless). Off by default.
ENABLE_GEO_LOOKUP=false

# Max request body size in bytes (DoS mitigation)
MAX_BODY_BYTES=16384


