# Public runtime configuration. All Vite-exposed vars MUST be prefixed VITE_.
# Copy this file to `.env.local` and fill in real values.

VITE_APP_NAME=HumSafar
VITE_APP_URL=http://localhost:5173

# API layer
VITE_API_BASE_URL=http://localhost:3001
VITE_API_TIMEOUT_MS=15000

# Cloudflare Turnstile — PUBLIC site key (safe to expose). Leave empty to disable.
# Get it at https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=

# Obscure admin panel path. MUST match the server's ADMIN_PATH_SECRET.
# The dashboard is served at /<VITE_ADMIN_PATH>. Keep it secret; never link to it.
VITE_ADMIN_PATH=change-me-to-a-random-url-segment



# Feature flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SCENE_STATS=false
VITE_ENABLE_LENIS=true

# Rendering
VITE_DPR_MIN=1
VITE_DPR_MAX=2
