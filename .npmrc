# React 19 is newer than some peer ranges declared by the react-three
# ecosystem (@react-three/drei, @react-spring/*) which still list react@^18.
# These libraries work fine with React 19 at runtime; the peer range is just
# stale. legacy-peer-deps lets npm install proceed instead of hard-failing
# (matches local behaviour and keeps Vercel/Render installs consistent).
legacy-peer-deps=true
